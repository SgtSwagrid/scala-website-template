# JVM binaries:
*.class
/META-INF/

# JVM logs:
*.log
hs_err_pid*

# Binary output directories:
target/
.jvm/
.js/

# Library output directories:
/sttp/

# Build tools:
/project/project
.metals/
.bsp/
.bloop
metals.sbt

# Share IntelliJ code style, dictionaries, templates, and plugins:
.idea/*
!.idea/codeStyles/
!.idea/dictionaries/
!.idea/fileTemplates/
!.idea/inspectionProfiles/
!.idea/runConfigurations/
!.idea/externalDependencies.xml
!.idea/file.template.settings.xml
!.idea/misc.xml
!.idea/scala_compiler.xml
!.idea/scala_settings.xml
!.idea/vcs.xml

# Share VSCode workspace settings and extensions:
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Agents:
.claude/settings.local.json
.claude/worktrees/
.playwright-mcp/
